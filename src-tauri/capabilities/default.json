{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for Mural windows",
  "windows": ["popover", "settings", "onboarding"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:window:allow-show",
    "core:window:allow-hide",
    "core:window:allow-close",
    "core:window:allow-set-focus",
    "core:window:allow-set-position",
    "core:window:allow-set-size",
    "core:window:allow-center",
    "core:event:default",
    "core:path:default",
    "core:resources:default",
    "core:webview:default",
    "core:tray:default",
    "core:menu:default",
    "core:image:default",
    "core:app:default",
    "dialog:default",
    "fs:default",
    "os:default",
    "shell:default"
  ]
}
